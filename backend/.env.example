# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=instantdeploy_user
DB_PASSWORD=instantdeploy_pass
DB_NAME=instantdeploy
AUTO_MIGRATE=true

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Server
PORT=8082
ENV=development

# Build Queue / Runtime
BUILD_WORKERS=3
BUILD_TIMEOUT=900
MAX_BUILD_RETRIES=3

# Docker
DOCKER_HOST=unix:///var/run/docker.sock

# Security
JWT_SECRET=your-secret-key-change-this

# Monitoring (Optional)
PROMETHEUS_ENABLED=true