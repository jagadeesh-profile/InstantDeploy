# Database
DATABASE_URL=postgres://instantdeploy_user:instantdeploy_pass@localhost:5432/instantdeploy?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# Server
PORT=8080
ENV=development

# Build settings
BUILD_WORKERS=3
BUILD_TIMEOUT=900
MAX_BUILD_RETRIES=2
BUILD_QUEUE_KEY=instantdeploy:build_queue

# Docker
DOCKER_HOST=unix:///var/run/docker.sock

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRY_MINUTES=120

# GitHub (optional — avoids rate limits on repo search)
# GITHUB_TOKEN=ghp_...

# Monitoring
PROMETHEUS_ENABLED=true
