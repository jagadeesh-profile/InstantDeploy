# Database
DATABASE_URL=postgres://instantdeploy_user:instantdeploy_pass@localhost:5432/instantdeploy?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379

# Server
PORT=8080
# ENV controls security behavior:
#   development — auto-generates JWT secret if missing, CORS reflects origin, verification codes shown in responses
#   production  — JWT_SECRET required, CORS restricted to CORS_ORIGINS, verification codes never in responses
ENV=development

# Build settings
BUILD_WORKERS=3
BUILD_TIMEOUT=900
MAX_BUILD_RETRIES=2
BUILD_QUEUE_KEY=instantdeploy:build_queue

# Runtime target: docker (default) or kubernetes
EXECUTION_MODE=docker

# Docker
DOCKER_HOST=unix:///var/run/docker.sock

# Auth — REQUIRED in production (min 32 chars recommended)
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_EXPIRY_MINUTES=120

# CORS — comma-separated list of allowed origins (empty = permissive in dev, blocked in prod)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# GitHub (optional — avoids rate limits on repo search)
# GITHUB_TOKEN=ghp_...

# Monitoring
PROMETHEUS_ENABLED=true

